# =============================================================================
# Upstox API credentials — template ONLY. Copy to .env and fill in real values.
# NEVER commit the real .env file. .gitignore must contain ".env".
# =============================================================================

# Upstox API key (issued via https://account.upstox.com/developers/apps)
UPSTOX_API_KEY=replace_me_with_real_api_key

# Upstox API secret (issued alongside the API key)
UPSTOX_API_SECRET=replace_me_with_real_api_secret

# Upstox redirect URI registered against the API key.
# Default for local dev: http://127.0.0.1:5000/callback
UPSTOX_REDIRECT_URI=http://127.0.0.1:5000/callback

# Deployable trading capital in INR. Used by the risk gate to compute
# per-trade risk as MAX_RISK_PER_TRADE_PCT * CAPITAL_INR.
# This is the ONLY capital input the risk gate accepts; it is intentionally
# kept outside config/risk_constants.py so it can be tuned per deployment.
CAPITAL_INR=200000

# Trading log level. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Production should be INFO. Per-tick diagnostics require DEBUG.
LOG_LEVEL=INFO

# Optional: pin the data directory. Default: ./data relative to project root.
DATA_DIR=./data
